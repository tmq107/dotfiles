#!/usr/bin/env bash
set -euo pipefail

SOURCE_DIR="${HOME}/personal/dotfiles"
HOME_DIR="${HOME}"
CONFIG_DIR="${HOME_DIR}/.config"
LOCAL_BIN_DIR="${HOME_DIR}/.local/bin"
LOCAL_SHARE_DIR="${HOME_DIR}/.local/share"
SSH_DIR="${HOME_DIR}/.ssh"
PI_SKILLS="${HOME}/personal/pi-agent/agent/skills"
KIRO_SKILLS="${CONFIG_DIR}/kiro/skills"

sync_nvim_lock() {
	local real_lock="${CONFIG_DIR}/nvim/nvim-pack-lock.json"
	local repo_lock="${SOURCE_DIR}/.config/nvim/nvim-pack-lock.json"
	mkdir -p "${CONFIG_DIR}/nvim" "${SOURCE_DIR}/.config/nvim"

	if [[ ! -f "${repo_lock}" && -f "${real_lock}" ]]; then
		cp -fp "${real_lock}" "${repo_lock}"
		echo "  nvim lock: seeded dotfiles from real"
		return
	fi
	if [[ ! -f "${real_lock}" && -f "${repo_lock}" ]]; then
		cp -fp "${repo_lock}" "${real_lock}"
		echo "  nvim lock: seeded real from dotfiles"
		return
	fi
	if [[ ! -f "${real_lock}" && ! -f "${repo_lock}" ]]; then
		echo "  nvim lock: none yet, skipping"
		return
	fi

	if cmp -s "${real_lock}" "${repo_lock}"; then
		echo "  nvim lock: in sync"
		return
	fi

	if [[ "${real_lock}" -nt "${repo_lock}" ]]; then
		cp -fp "${real_lock}" "${repo_lock}"
		echo "  nvim lock: real -> dotfiles (real newer)"
	elif [[ "${repo_lock}" -nt "${real_lock}" ]]; then
		cp -fp "${repo_lock}" "${real_lock}"
		echo "  nvim lock: dotfiles -> real (dotfiles newer)"
	else
		cp -fp "${real_lock}" "${repo_lock}"
		echo "  nvim lock: real -> dotfiles (content differed, equal mtime)"
	fi
}

echo "Starting ProSync dotfile sync..."

echo "Syncing dotfiles..."
cp -f "${SOURCE_DIR}/.envrc" "${HOME_DIR}/.envrc"
cp -f "${SOURCE_DIR}/.aliases" "${HOME_DIR}/.aliases"
cp -f "${SOURCE_DIR}/.p10k.zsh" "${HOME_DIR}/.p10k.zsh"
cp -f "${SOURCE_DIR}/.zshrc" "${HOME_DIR}/.zshrc"
cp -f "${SOURCE_DIR}/.funrc" "${HOME_DIR}/.funrc"

echo "Syncing nvim lock (two-way, newest wins)..."
sync_nvim_lock

echo "Syncing .config..."
mkdir -p "${CONFIG_DIR}"
cp -rf "${SOURCE_DIR}/.config/." "${CONFIG_DIR}/"

echo "Copy .local binary"
mkdir -p "${LOCAL_BIN_DIR}"
cp -rf "${SOURCE_DIR}/.local/bin/." "${LOCAL_BIN_DIR}/"
chmod +x "${LOCAL_BIN_DIR}/"*

echo "Copy .local share"
mkdir -p "${LOCAL_SHARE_DIR}"
cp -rf "${SOURCE_DIR}/.local/share/." "${LOCAL_SHARE_DIR}/"

if command -v kiro-cli >/dev/null 2>&1; then
	echo "Syncing Pi skill to Kiro"
	mkdir -p "${KIRO_SKILLS}"
	cp -rf "${PI_SKILLS}/." "${KIRO_SKILLS}/"
fi

echo "ProSync complete!"
echo "Run: source ~/.zshrc"
